# Pflicht: dein Anthropic API-Key (nur serverseitig – NIE ins Frontend!)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Modell für die Mahlzeit-Analyse (Standard: claude-haiku-4-5 = günstig).
# Für höhere Genauigkeit: claude-sonnet-4-6
MEAL_MODEL=claude-haiku-4-5

# Optional: einfacher Schutz-Token. Wenn gesetzt, muss die App ihn als Bearer mitsenden
# (im Scanner unter „KI-Endpunkt" eintragen). Leer lassen = Endpunkt offen.
MEAL_API_TOKEN=
