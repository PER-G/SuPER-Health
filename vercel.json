{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "functions": { "api/**/*.js": { "memory": 1024, "maxDuration": 30 } },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/tracking", "destination": "/SuPER-Health-Tracking.html" },
    { "source": "/tracker", "destination": "/SuPER-Health-Tracking.html" },
    { "source": "/", "destination": "/SuPER-Health.html" }
  ]
}
